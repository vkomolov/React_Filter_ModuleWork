@import "../../utils/global_styles/variables";
@import "../../utils/global_styles/mixins";
@import "../../utils/global_styles/animations";

.topWrapper {
  width: 240px;
  height: 240px;
  padding: 10px;
  margin: 10px 20px;
  background: linear-gradient(120deg, $white, $foxyLight);
  transform: scale(0);
  @include box-shadow(1px, 5px, $greyNorm);
  animation: scaleUpZero .4s ease forwards;

  .tag {
    @include init-font(18px, 400);
    display: inline-block;
    margin-top: 5px;
    margin-bottom: 5px;

    &:not(:last-child) {
      margin-right: 10px;
    }

    &.active {
      color: $foxy;
      animation: popup .4s ease-in-out infinite;
    }
  }

  .tagsBlock {
    @include flex-box($flex-box-row-left...);
    margin: 10px 0;
  }

  .heading {
    @include init-font(28px, 700);
    color: $foxy;
  }
}