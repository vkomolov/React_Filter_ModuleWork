@import "../../utils/global_styles/variables";
@import "../../utils/global_styles/mixins";
@import "../../utils/global_styles/animations";

.inputWrapper {
  padding: 5px;
  border: 5px solid $foxy;
  border-radius: 12px;
  background-color: $white;
  box-shadow: inset 1px 1px 4px $greyDark;


  input {
    @include init-font(18px, 400);
    color: $greyNorm;
    border: none;
    background-color: transparent;
  }
}

